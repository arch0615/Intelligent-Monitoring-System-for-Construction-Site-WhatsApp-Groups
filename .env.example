# =====================================================================
# Modelo de variáveis de ambiente — copie para .env e preencha.
# NUNCA versione o .env real (ver .gitignore).
# =====================================================================

# --- PostgreSQL ---
POSTGRES_USER=obras
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=obras_monitor
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
# Nome do stream/fila que liga captura -> pipeline
REDIS_STREAM=captura:eventos
REDIS_CONSUMER_GROUP=pipeline

# --- API Claude (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Modelo de classificação (pendência/dúvida/decisão + urgência)
CLAUDE_MODEL=claude-opus-4-8

# --- Captura (Baileys / número de monitoramento) ---
# Número dedicado em formato internacional, só dígitos (ex.: 5511999998888)
WA_PHONE_NUMBER=
# Número de BACKUP (Plano B) — usado na troca rápida em caso de bloqueio.
# A troca é operacional: o backup é adicionado aos grupos e reconectado.
WA_BACKUP_PHONE_NUMBER=
# Diretório onde a sessão do WhatsApp é persistida (reconexão / Plano B)
WA_AUTH_DIR=./auth_state

# --- Armazenamento de mídia ---
# Caminho no contêiner; mapeado para ./media no host via docker-compose
MEDIA_DIR=/media

# --- Alertas + Relatório diário — Telegram (NÃO usar o nº de monitoramento) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Relatório diário (Etapa 3) — horário do disparo (cron, fuso TZ abaixo) ---
RELATORIO_HORA=18
RELATORIO_MINUTO=0

# --- Alertas proativos (Etapa 4) — urgências que disparam alerta imediato ---
# As demais (media/baixa) aguardam o relatório diário.
ALERTA_URGENCIAS=critica,alta

# --- Retenção de mídia (Etapa 5) — dias até remover o binário do disco.
# Metadados e texto/análise permanecem no banco. 0 = nunca arquivar.
RETENCAO_MIDIA_DIAS=90

# --- Vídeo (RF-06) ---
# Intervalo (segundos) entre frames extraídos pelo ffmpeg (P-05, configurável)
VIDEO_FRAME_INTERVAL_SECONDS=10

# --- Whisper (transcrição local, sem custo de API) ---
WHISPER_MODEL=small
WHISPER_COMPUTE_TYPE=int8

# --- Ambiente ---
LOG_LEVEL=info
TZ=America/Sao_Paulo
